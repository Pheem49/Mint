{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "allowJs": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": false,
    "outDir": "./out",
    "rootDir": "./src",
    "esModuleInterop": true,
    "types": ["node"]
  },
  "include": [
    "src/main/**/*",
    "src/preload/**/*",
    "src/System/**/*",
    "src/AI_Brain/**/*",
    "src/Plugins/**/*",
    "src/Automation_Layer/**/*",
    "src/Command_Parser/**/*",
    "src/Channels/**/*"
  ],
  "exclude": [
    "node_modules",
    "out",
    "dist",
    "src/renderer/**/*"
  ]
}
