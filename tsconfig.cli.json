{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "allowJs": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "outDir": "./dist",
    "rootDir": "./"
  },
  "include": [
    "mint-cli.ts",
    "mint-cli-logic.ts",
    "src/CLI/**/*",
    "src/System/**/*",
    "src/AI_Brain/**/*",
    "src/Plugins/**/*",
    "src/Automation_Layer/**/*",
    "src/Command_Parser/**/*",
    "src/Channels/**/*"
  ],
  "exclude": [
    "node_modules",
    "out",
    "dist"
  ]
}
