{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mint",
  "version": "1.6.0",
  "identifier": "com.pheem49.mint",
  "build": {
    "beforeDevCommand": "npm run dev:desktop",
    "beforeBuildCommand": "npm run build:desktop:ui",
    "devUrl": "http://localhost:9000",
    "frontendDist": "../out/renderer"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mint",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640,
        "transparent": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["main"],
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/.config/mint/**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "../assets/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": []
    }
  }
}
