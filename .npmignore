# Exclude Electron builds
dist/
release/

# Exclude sensitive files
.env
.env.example
mint-config.json
mint-chat-history.json
mint-knowledge.json

# Exclude local project artifacts
task.md
walkthrough.md
implementation_plan.md
BUILD_AND_RELEASE.md
NPM_PUBLISH_GUIDE.md
RELEASE_NOTES.md
scratch/
tech_news.txt
test_knowledge.txt
index.html
.codex

# Exclude tests and documentation site artifacts from the npm runtime package
tests/
docs/

# Exclude compressed model source archives; keep extracted runtime model files
models/**/*.zip

# Exclude Git files
.git/
.github/
.gitignore

# Keep assets for README but ignore if too large (optional)
# assets/
