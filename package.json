{
  "name": "@pheem49/mint",
  "version": "1.3.0",
  "description": "A powerful Electron-based AI desktop assistant powered by Google Gemini, featuring screen vision, web automation, and proactive suggestions.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:linux": "electron-builder --linux",
    "cli": "node mint-cli.js"
  },
  "bin": {
    "mint": "mint-cli.js"
  },
  "keywords": [],
  "author": {
    "name": "Pheem49",
    "email": "killerpheem13@gmail.com"
  },
  "license": "AGPL-3.0-only",
  "type": "commonjs",
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@inkjs/ui": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.13.6",
    "blessed": "^0.1.81",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.38.0",
    "google-tts-api": "^2.0.2",
    "ink": "^7.0.1",
    "ink-text-input": "^6.0.0",
    "inquirer": "^13.4.1",
    "lucide-react": "^1.9.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "puppeteer": "^24.38.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.10"
  },
  "build": {
    "appId": "com.pheem49.mint",
    "productName": "Mint",
    "executableName": "mint-ai",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "files": [
      "**/*",
      "!node_modules/.cache/**"
    ],
    "linux": {
      "icon": "assets/icon.png",
      "executableName": "mint-ai",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "deb": {
      "packageName": "mint-ai",
      "artifactName": "mint-ai_${version}_${arch}.${ext}"
    }
  }
}
