{
  "name": "@pheem49/mint",
  "version": "1.5.2",
  "description": "A powerful Electron-based AI desktop assistant powered by Google Gemini, featuring screen vision, web automation, and proactive suggestions.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "jest --testPathPatterns=tests/",
    "test:watch": "jest --testPathPatterns=tests/ --watch",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --linux --mac --win",
    "cli": "node mint-cli.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/AI_Brain/memory_store.js",
      "src/AI_Brain/knowledge_base.js",
      "src/System/config_manager.js"
    ]
  },
  "bin": {
    "mint": "mint-cli.js"
  },
  "keywords": [],
  "author": {
    "name": "Pheem49",
    "email": "killerpheem13@gmail.com"
  },
  "license": "AGPL-3.0-only",
  "type": "commonjs",
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@hazart-pkg/live2d-core": "^1.0.1",
    "@inkjs/ui": "^2.0.0",
    "@line/bot-sdk": "^11.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@slack/bolt": "^4.7.2",
    "axios": "^1.13.6",
    "blessed": "^0.1.81",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "discord.js": "^14.26.4",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "ink": "^7.0.1",
    "ink-text-input": "^6.0.0",
    "inquirer": "^13.4.1",
    "lucide-react": "^1.9.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^6.5.10",
    "puppeteer": "^24.38.0",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "read-excel-file": "^9.0.9",
    "telegraf": "^4.16.3",
    "whatsapp-web.js": "^1.34.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "jest": "^30.4.0",
    "vite": "^8.0.10"
  },
  "build": {
    "appId": "com.pheem49.mint",
    "productName": "Mint",
    "executableName": "mint-ai",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "files": [
      "**/*",
      "!node_modules/.cache/**"
    ],
    "linux": {
      "icon": "assets/icon.png",
      "executableName": "mint-ai",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "mac": {
      "icon": "assets/icon.png",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "deb": {
      "packageName": "mint-ai",
      "artifactName": "mint-ai_${version}_${arch}.${ext}"
    }
  }
}
